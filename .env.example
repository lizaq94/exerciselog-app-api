# Basic application configuration
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/exerciselog
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/exerciselog
APP_VERSION=1.0.0

# JWT Configuration
JWT_ACCESS_TOKEN_SECRET=supersecretkey
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_SECRET=supersecretrefreshkey
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# Mail configuration
MAIL_HOST=smtp.example.com
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=password
MAIL_FROM=no-reply@exerciselog.com

# Object storage configuration (S3-compatible — Cloudflare R2)
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_BUCKET_NAME=exerciselog
# Public URL of the bucket (custom domain connected in Cloudflare)
S3_PUBLIC_URL=https://img.your-domain.com

# OpenRouter Configruation
OPEN_ROUTER_API_KEY=your_api_key
OPEN_ROUTER_API_URL=https://openrouter.ai/api/v1