  staging.exerciselog.app {
      reverse_proxy app:3000
  }

  api.exerciselog.app {
      reverse_proxy {
          dynamic a {
              name      app-prod
              port      3000
              refresh   5s
              resolvers 127.0.0.11
          }

          health_uri        /health
          health_port       3000
          health_interval   10s
          health_timeout    3s
          health_status     2xx

          fail_duration 30s
          max_fails     1

          lb_try_duration   5s
          lb_try_interval   250ms
      }
  }